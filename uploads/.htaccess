# Defence-in-depth: block direct HTTP access to this directory.
#
# On Apache with mod_rewrite the root .htaccess routes all requests for
# uploads/ through serve_upload.php (which enforces authentication) before
# they ever reach this directory, so this rule is normally never hit.
#
# If mod_rewrite is unavailable or misconfigured this rule acts as a
# last-resort guard and returns 403 for every direct file request.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
