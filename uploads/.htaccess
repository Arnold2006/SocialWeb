# Defence-in-depth: block direct HTTP access to this directory.
#
# When mod_rewrite is active the root .htaccess routes every request for
# uploads/ through serve_upload.php (which enforces authentication), so
# the deny rules below are intentionally wrapped in <IfModule !mod_rewrite.c>
# to avoid blocking those internally-rewritten requests.
#
# The deny rules only activate when mod_rewrite is unavailable or disabled,
# acting as a last-resort guard that returns 403 for direct file requests.

<IfModule !mod_rewrite.c>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</IfModule>
