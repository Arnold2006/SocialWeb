# Defence-in-depth: block direct HTTP access to this directory.
#
# When mod_rewrite is active the root .htaccess routes every request for
# uploads/ through serve_upload.php (which enforces authentication), so
# the deny rules below do not interfere with PHP's readfile()-based serving.
#
# The deny is intentionally unconditional so that direct file access is
# blocked even when mod_rewrite is loaded but RewriteEngine is disabled
# at the server level.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
